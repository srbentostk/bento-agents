{
  "name": "bento-agents",
  "displayName": "Bento Agents",
  "description": "Pixel art office where your Claude Code agents come to life as animated characters — Agência B.E.N.T.O.",
  "version": "1.5.3",
  "publisher": "mechamedebento",
  "repository": {
    "type": "git",
    "url": "https://github.com/srbentostk/bento-agents"
  },
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Bento Agents",
      "properties": {
        "bento-agents.notificationsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable VS Code notifications when an agent asks for permission in a terminal"
        }
      }
    },
    "commands": [
      {
        "command": "bento-agents.showPanel",
        "title": "Bento Agents: Show Panel"
      },
      {
        "command": "bento-agents.exportDefaultLayout",
        "title": "Bento Agents: Export Layout as Default"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "bento-agents-panel",
          "title": "Bento Agents",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "bento-agents-panel": [
        {
          "type": "webview",
          "id": "bento-agents.panelView",
          "name": "Bento Agents"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "build:webview": "cd webview-ui && npm run build",
    "compile": "npm run check-types && npm run lint && node esbuild.js && npm run build:webview",
    "build": "npm run compile",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run build:webview",
    "check-types": "tsc --noEmit",
    "prepare": "husky",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:webview": "cd webview-ui && npm run lint",
    "lint:webview:fix": "cd webview-ui && eslint . --fix",
    "import-tileset": "tsx scripts/import-tileset-cli.ts",
    "format": "prettier --write \"src/**/*.ts\" \"webview-ui/src/**/*.{ts,tsx,css}\" \"*.{js,mjs}\" \"webview-ui/*.{js,ts}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"webview-ui/src/**/*.{ts,tsx,css}\" \"*.{js,mjs}\" \"webview-ui/*.{js,ts}\"",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:debug": "playwright test --config e2e/playwright.config.ts --debug"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "25.x",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.105.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "npm-run-all": "^4.1.5",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix",
    "webview-ui/src/**/*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,js,mjs,css,json,md}": "prettier --write",
    "webview-ui/**/*.{ts,tsx,js,css,json}": "prettier --write"
  }
}
